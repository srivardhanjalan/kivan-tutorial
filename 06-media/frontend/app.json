{
  "expo": {
    "name": "Kivan",
    "slug": "kivan-app",
    "scheme": "kivan",
    "version": "0.2.0",
    "orientation": "portrait",
    "icon": "./assets/kivan.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/kivan.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kivan.app"
    },
    "android": {
      "package": "com.kivan.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/kivan.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser"
    ]
  }
}
